# Lantern (Gesher) — environment variables.
# Copy this file to .env.local and paste real values. NEVER commit .env.local.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only.

# --- Supabase (Steps 2-3) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — must NEVER reach the browser or Git.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend email (Step 6) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Daily video (Step 8) ---
DAILY_API_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
